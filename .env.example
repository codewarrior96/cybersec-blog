# Storage policy:
# - SOC_STORAGE=memory  -> demo / stateless mode (default)
# - SOC_STORAGE=sqlite  -> durable local sqlite store
# SOC_STORAGE=memory

# Supabase attack metrics storage
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Optional override (default: attack_events)
# SUPABASE_ATTACK_EVENTS_TABLE=attack_events

# Memory store HMAC signing secret (R-20 hardening, Phase 1.5.1)
# REQUIRED — module throws at import-time if unset.
# Generate strong random:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production AND Preview: set in Vercel dashboard with SEPARATE random values per env.
# (Preview leak production'ı düşürmesin diye env başına ayrı secret.)
SOC_DEMO_SECRET=YOUR_RANDOM_HEX_SECRET

# Trust proxy headers (X-Forwarded-For, X-Real-IP) for client IP resolution
# REQUIRED for Vercel deployment — set 1 in Production + Preview env.
# Without it, the client-ip helper falls back to connection IP only (Vercel
# edge node IP), collapsing per-IP rate limits to a single shared bucket.
# Acceptable values: 1 or true (explicit opt-in).
# Default if unset: false (fail-closed — security-first default).
# Local dev without a proxy: leave unset or set to 0.
TRUST_PROXY_HEADERS=

# Critical memory fallback policy (R-03, audit Section 2 — fix scope deferred
# to Phase 1.5.7 per A-10 amendment narrative correction).
# Controls whether soc-store-adapter silently routes to in-memory store when
# the configured backend (sqlite) fails. Consumed in
# src/lib/soc-store-adapter.ts L17-19 (current implementation).
#
# Current behavior (Phase 1.5.7 R-03 fix will revise):
#   - NODE_ENV=production → auto-enables fallback (=1 equivalent), regardless
#     of explicit env value
#   - Otherwise → defaults to disabled
#
# Phase 1.5.7 will change semantics to explicit-opt-in only (R-20/R-01 pattern:
# unset → fail-closed). After that fix lands, production deployments must set
# SOC_ALLOW_CRITICAL_MEMORY_FALLBACK=1 explicitly to retain fallback behavior.
#
# Vercel deployment guidance (operator action between Phase 1.5.7.0 push and
# Phase 1.5.7 push):
#   - Currently unset is acceptable for THIS commit (production behavior
#     unchanged — auto-enable via NODE_ENV=production still active)
#   - To pre-set explicit policy before Phase 1.5.7 lands:
#       =0 → fail-closed (no fallback on sqlite failure; thrown error reaches
#            caller; aligns with R-20/R-01 fail-loud pattern)
#       =1 → explicit opt-in fallback (retains current production behavior
#            after Phase 1.5.7 removes the NODE_ENV auto-enable)
#   - Default recommendation if choosing explicit set: =0 (security-first
#     default; explicit opt-in to degraded mode)
# Local dev: leave unset (default safe behavior).
SOC_ALLOW_CRITICAL_MEMORY_FALLBACK=
