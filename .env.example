# Storage policy:
# - SOC_STORAGE=memory  -> demo / stateless mode (default)
# - SOC_STORAGE=sqlite  -> durable local sqlite store
# SOC_STORAGE=memory

# Supabase attack metrics storage
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Optional override (default: attack_events)
# SUPABASE_ATTACK_EVENTS_TABLE=attack_events

# Memory store HMAC signing secret (R-20 hardening, Phase 1.5.1)
# REQUIRED — module throws at import-time if unset.
# Generate strong random:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production AND Preview: set in Vercel dashboard with SEPARATE random values per env.
# (Preview leak production'ı düşürmesin diye env başına ayrı secret.)
SOC_DEMO_SECRET=YOUR_RANDOM_HEX_SECRET
