# Storage policy:
# - SOC_STORAGE=memory  -> demo / stateless mode (default)
# - SOC_STORAGE=sqlite  -> durable local sqlite store
# SOC_STORAGE=memory

# Supabase attack metrics storage
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
# Optional override (default: attack_events)
# SUPABASE_ATTACK_EVENTS_TABLE=attack_events
